  "RES_GEO_BASE_PERCEIVE": {
    "resource_type": "3d_sandbox",
    "ai_guide_text": "",
    "sandbox_config": {
      "available_shapes": ["rectangle", "cube", "circle", "sphere", "cylinder", "cone"],
      "default_shape": "rectangle"
    },
    "shape_parameters": {
      "rectangle": {
        "sliders": [
          {"param": "w", "label": "长度 (l)", "min": 1, "max": 5, "default": 3},
          {"param": "h", "label": "宽度 (w)", "min": 1, "max": 5, "default": 2}
        ],
        "formulas": {
          "perimeter": "C = 2 * (l + w)",
          "area": "S = l * w"
        }
      },
      "cube": {
        "sliders": [
          {"param": "w", "label": "长度 (l)", "min": 1, "max": 5, "default": 3},
          {"param": "h", "label": "宽度 (w)", "min": 1, "max": 5, "default": 2},
          {"param": "d", "label": "高度 (h)", "min": 1, "max": 5, "default": 2}
        ],
        "formulas": {
          "surface_area": "S = 2 * (l*w + w*h + l*h)",
          "volume": "V = l * w * h"
        }
      },
      "circle": {
        "sliders": [
          {"param": "r", "label": "半径 (r)", "min": 1, "max": 4, "default": 2},
          {"param": "a", "label": "角度 (a)", "min": 0, "max": 360, "default": 360}
        ],
        "formulas": {
          "perimeter": "C = (a/360) * 2πr + 2r",
          "area": "S = (a/360) * π * r²"
        }
      },
      "sphere": {
        "sliders": [
          {"param": "r", "label": "半径 (r)", "min": 1, "max": 4, "default": 2}
        ],
        "formulas": {
          "surface_area": "S = 4 * π * r²",
          "volume": "V = 4/3 * π * r³"
        }
      },
      "cylinder": {
        "sliders": [
          {"param": "r", "label": "底面半径 (r)", "min": 1, "max": 4, "default": 2},
          {"param": "h", "label": "高度 (h)", "min": 1, "max": 6, "default": 4}
        ],
        "formulas": {
          "surface_area": "S = 2πr² + 2πrh",
          "volume": "V = π * r² * h"
        }
      },
      "cone": {
        "sliders": [
          {"param": "r", "label": "底面半径 (r)", "min": 1, "max": 4, "default": 2},
          {"param": "h", "label": "高度 (h)", "min": 1, "max": 6, "default": 4}
        ],
        "formulas": {
          "surface_area": "S = πr² + πrl (其中母线 l = sqrt(r² + h²))",
          "volume": "V = 1/3 * π * r² * h"
        }
      }
    }
  },
  
  "RES_GEO_COMPREHENSIVE_QUIZ": {
    "resource_type": "3d_interactive_quiz",
    "is_multi_question": true,
    "questions": [
      {
        "id": "q1",
        "ai_guide_text": "【第一题：城堡瞭望塔】挑战开始！这里有一个由长方体基座和圆柱形塔楼组成的复合建筑模型。请发挥你的空间想象力，解决下面的实际问题：",
        "three_config": {
          "scene_type": "composite_building",
          "components": [
            {"type": "box", "size": [6, 4, 3], "position": [0, 1.5, 0], "color": "#a0aec0"},
            {"type": "cylinder", "size": [1.5, 1.5, 5], "position": [0, 5.5, 0], "color": "#ed8936"}
          ]
        },
        "quiz_data": {
          "question_text": "我们要给这个建筑的外表面刷上蓝色油漆（与地面接触的底面不刷）。已知长方体基座长6米、宽4米、高3米；圆柱塔楼底面半径1.5米、高5米。求需要粉刷的总面积是多少平方米？（π取3.14，结果保留整数）",
          "options": [
            {"key": "A", "text": "123 平方米"},
            {"key": "B", "text": "144 平方米"},
            {"key": "C", "text": "131 平方米"}
          ],
          "correct_answer": "C",
          "analysis": "解题思路：总面积 = 长方体表面积(扣除底面及与圆柱重合面) + 圆柱侧面积 + 圆柱顶面积。通过 3D 旋转观察可以更清楚地看到被隐藏和重叠的部分。"
        }
      },
      {
        "id": "q2",
        "ai_guide_text": "【第二题：方圆石柱工件】接下来观察一个工业组合工件。一个底面边长为4分米、高6分米的正方体石柱，正中心从上到下被掏空出了一个半径为1分米的圆柱形通孔。",
        "three_config": {
          "scene_type": "hollow_pillar",
          "components": [
            {"type": "box", "size": [4, 6, 4], "position": [0, 3, 0], "color": "#cbd5e1"},
            {"type": "cylinder", "size": [1, 1, 6.1], "position": [0, 3, 0], "color": "#f8fafc"}
          ]
        },
        "quiz_data": {
          "question_text": "请问这个被掏空后的石柱工件，其剩余部分的总体积是多少立方分米？（π取3.14）",
          "options": [
            {"key": "A", "text": "77.16 立方分米"},
            {"key": "B", "text": "96.00 立方分米"},
            {"key": "C", "text": "58.32 立方分米"}
          ],
          "correct_answer": "A",
          "analysis": "解题思路：剩余体积 = 外围长方体体积 - 内部圆柱通孔体积。长方体体积 = 4 × 4 × 6 = 96；圆柱体积 = 3.14 × 1² × 6 = 18.84。两者相减：96 - 18.84 = 77.16。"
        }
      },
      {
        "id": "q3",
        "ai_guide_text": "【第三题：双层生日蛋糕】这是一个双层蛋糕模型。下层是一个半径为3分米、高2分米的圆柱；上层是一个半径为2分米、高2分米的圆柱，它们轴心重合重叠在一起。",
        "three_config": {
          "scene_type": "double_cake",
          "components": [
            {"type": "cylinder", "size": [3, 3, 2], "position": [0, 1, 0], "color": "#fbcfe8"},
            {"type": "cylinder", "size": [2, 2, 2], "position": [0, 3, 0], "color": "#fde047"}
          ]
        },
        "quiz_data": {
          "question_text": "现在需要给这个双层蛋糕的外露表面（不含最底下与桌面接触的面）涂满一层奶油，请问需要涂奶油的面积是多少平方分米？（π取3.14）",
          "options": [
            {"key": "A", "text": "62.80 平方分米"},
            {"key": "B", "text": "91.06 平方分米"},
            {"key": "C", "text": "78.50 平方分米"}
          ],
          "correct_answer": "B",
          "analysis": "解题思路：外露表面积 = 下层圆柱侧面积 + 上层圆柱侧面积 + 下层顶面外露环形面积 + 上层顶面面积。其实通过空间转化，所有顶层和外露环形的面积之和，正好等于“最下层圆柱的顶面积”。因此：总奶油面积 = 2×3.14×3×2 (下侧面) + 2×3.14×2×2 (上侧面) + 3.14×3² (最大底面影投) = 37.68 + 25.12 + 28.26 = 91.06。"
        }
      },
      {
        "id": "q4",
        "ai_guide_text": "【第四题：沙漏与沙堆】将一个半径为3厘米、高6厘米的圆锥形沙漏容器装满沙子，然后全部漏到平整的地面上，形成了一个完美的圆锥形沙堆，已知沙堆的高度为2厘米。",
