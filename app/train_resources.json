          ]
        },
        "quiz_data": {
          "question_text": "为了评估储气能力，工程师需要计算这个储气罐的整体容积。请问该胶囊储气罐的总体积是多少立方米？（π取3.14）",
          "options": [
            {"key": "A", "text": "108.82 立方米"},
            {"key": "B", "text": "75.36 立方米"},
